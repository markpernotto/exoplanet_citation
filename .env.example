# Copy this file to .env and fill in real values. Never commit .env.

# Postgres (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/exoplanet_citation?sslmode=require

# dbt connection (parsed from your DATABASE_URL above; dbt-postgres needs them split)
DBT_HOST=ep-xxx.region.aws.neon.tech
DBT_USER=user
DBT_PASSWORD=password
DBT_DBNAME=exoplanet_citation
DBT_PORT=5432
DBT_SCHEMA=public

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=exoplanet-citation-snapshots
R2_ENDPOINT_URL=https://your-cloudflare-account-id.r2.cloudflarestorage.com

# NASA ADS API token (Phase 2)
ADS_API_TOKEN=your-ads-token

# Polite-pool identification — required by Crossref, encouraged by ADS
USER_AGENT_EMAIL=mark@pernotto.com
USER_AGENT_PROJECT=exoplanet_citation/0.1 (+https://github.com/markpernotto/exoplanet_citation)
